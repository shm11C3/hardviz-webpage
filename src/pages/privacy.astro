---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Privacy from "../components/Privacy.astro";
import { getLangFromUrl } from "../i18n/utils";
import Layout from "../layouts/Layout.astro";
import { getPrivacyEntry } from "../lib/privacy";

const lang = getLangFromUrl(Astro.url);
const entry = await getPrivacyEntry(lang);
---

<Layout
  title={entry.data.metaTitle}
  lang={lang}
  description={entry.data.metaDescription}
>
  <Header />
  <main id="main-content"><Privacy entry={entry} /></main>
  <Footer />
</Layout>
