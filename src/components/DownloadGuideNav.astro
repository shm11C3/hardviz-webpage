---
import type { ui } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import { addJapaneseLineBreaks } from "../lib/japaneseLineBreaks";

interface Props {
  lang: keyof typeof ui;
  current: "download" | "verification";
  downloadHref: string;
  verificationHref: string;
}

const { lang, current, downloadHref, verificationHref } = Astro.props;
const t = useTranslations(lang);
const formatText = (text: string) => addJapaneseLineBreaks(lang, text);

const baseLinkClass =
  "block min-w-0 break-words rounded-md px-2.5 py-2 font-medium transition-colors sm:px-3";
const downloadChildren = [
  {
    href: `${downloadHref}#download`,
    label: formatText(t("download.nav.downloadInstaller")),
  },
  {
    href: `${downloadHref}#installation`,
    label: formatText(t("download.nav.installation")),
  },
] as const;
---

<nav
  class="top-28 w-full min-w-0 max-w-full overflow-hidden rounded-lg border border-slate-200 bg-white p-2.5 text-[0.8125rem] shadow-sm sm:p-3 sm:text-sm lg:sticky lg:self-start dark:border-slate-700 dark:bg-slate-900"
  aria-label={t("download.nav.ariaLabel")}
  data-download-guide-nav
>
  <div class="space-y-1">
    <a
      href={downloadHref}
      class:list={[
        baseLinkClass,
        current === "download"
          ? "bg-cyan-50 text-cyan-700 dark:bg-cyan-950/40 dark:text-cyan-300"
          : "text-slate-600 hover:bg-slate-50 hover:text-cyan-700 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-cyan-300",
      ]}
      aria-current={current === "download" ? "page" : undefined}
      data-astro-prefetch
    >
      {formatText(t("download.nav.download"))}
    </a>
    <div
      class="ml-2 min-w-0 space-y-1 border-slate-200 border-l pl-2 sm:ml-3 sm:pl-3 dark:border-slate-700"
    >
      {downloadChildren.map((item) => (
        <a
          href={item.href}
          class="block min-w-0 break-words rounded-md px-2.5 py-1.5 text-slate-500 transition-colors hover:bg-slate-50 hover:text-cyan-700 sm:px-3 dark:text-slate-400 dark:hover:bg-slate-800 dark:hover:text-cyan-300"
          data-astro-prefetch
        >
          {item.label}
        </a>
      ))}
    </div>
    <a
      href={verificationHref}
      class:list={[
        baseLinkClass,
        current === "verification"
          ? "bg-cyan-50 text-cyan-700 dark:bg-cyan-950/40 dark:text-cyan-300"
          : "text-slate-600 hover:bg-slate-50 hover:text-cyan-700 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-cyan-300",
      ]}
      aria-current={current === "verification" ? "page" : undefined}
      data-astro-prefetch
    >
      {formatText(t("download.nav.verification"))}
    </a>
  </div>
</nav>
