---
import { render } from "astro:content";
import { ShieldCheck } from "lucide-react";
import type { ui } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";
import type { DownloadGuideEntry } from "../lib/downloadGuide";
import { addJapaneseLineBreaks } from "../lib/japaneseLineBreaks";
import type { LatestReleaseDetails } from "../lib/latestRelease";
import type { PlatformDownload } from "../types/platform";
import Download from "./Download.tsx";
import DownloadGuideNav from "./DownloadGuideNav.astro";

interface Props {
  lang: keyof typeof ui;
  downloads: PlatformDownload[];
  latestVersion: string | null;
  latestReleaseDetails: LatestReleaseDetails;
  changelogHref: string;
  downloadHref: string;
  verificationHref: string;
  sourceCheckEntry: DownloadGuideEntry;
  installationEntry: DownloadGuideEntry;
}

const {
  lang,
  downloads,
  latestVersion,
  latestReleaseDetails,
  changelogHref,
  downloadHref,
  verificationHref,
  sourceCheckEntry,
  installationEntry,
} = Astro.props;

const t = useTranslations(lang);
const formatText = (text: string) => addJapaneseLineBreaks(lang, text);

const { Content: InstallationContent } = await render(
  installationEntry as never,
);
const { Content: SourceCheckContent } = await render(sourceCheckEntry as never);

const guideArticleClass =
  "prose prose-sm prose-slate mx-auto max-w-full min-w-0 sm:prose-base dark:prose-invert sm:max-w-3xl prose-a:text-cyan-700 dark:prose-a:text-cyan-300 prose-blockquote:border-cyan-500 prose-code:break-words prose-pre:max-w-full prose-pre:overflow-x-auto prose-pre:whitespace-pre prose-pre:rounded-none prose-pre:border-slate-800 prose-pre:border-l-4 prose-pre:bg-slate-950 prose-pre:text-cyan-100 prose-pre:text-[0.8125rem] sm:prose-pre:text-sm";

const downloadTranslations = {
  button: t("download.button"),
  noDownloads: t("download.noDownloads"),
  sha256: t("download.verify.sha256"),
  copySha256: t("download.verify.copySha256"),
  copied: t("download.verify.copied"),
  checksumUnavailable: t("download.verify.checksumUnavailable"),
};

const pageTitleSeparator = t("download.pageTitleSeparator");
---

<section class="bg-white pt-16 pb-20 dark:bg-slate-800">
  <div class="container mx-auto px-4">
    <div
      class="mx-auto grid max-w-7xl min-w-0 gap-8 lg:grid-cols-[minmax(0,13rem)_minmax(0,1fr)] lg:gap-10"
    >
      <DownloadGuideNav
        lang={lang}
        current="download"
        downloadHref={downloadHref}
        verificationHref={verificationHref}
      />

      <div class="min-w-0">
        <div class:list={["max-w-6xl min-w-0", lang === "ja" && "budoux-ja"]}>
          <h1
            class="font-bold text-3xl text-slate-950 leading-tight md:text-5xl dark:text-white"
          >
            <span class="inline-block"
              >{t("download.pageTitleBeforeBreak")}</span
            >
            <span class="hidden sm:inline">{pageTitleSeparator}</span>
            <br class="sm:hidden">
            <span class="inline-block"
              >{t("download.pageTitleAfterBreak")}</span
            >
          </h1>
          <p
            class="mt-4 max-w-3xl text-base text-slate-600 leading-7 md:text-lg dark:text-slate-300"
          >
            {formatText(t("download.pageDescription"))}
          </p>
          <div
            class="mt-5 space-y-2 text-slate-500 text-sm dark:text-slate-400"
          >
            <p>
              {latestVersion ? `${t("download.currentVersion")} v${latestVersion}` : t("download.currentVersion")}
            </p>
            {latestReleaseDetails.publishedAt ? (
              <p>
                {t("download.releaseDate")} {latestReleaseDetails.publishedAt}
              </p>
            ) : null}
            <a
              href={changelogHref}
              class="inline-flex font-medium text-slate-700 hover:text-slate-950 hover:underline dark:text-slate-200 dark:hover:text-white"
              data-astro-prefetch
            >
              {t("download.latestChangesLink")}
            </a>
          </div>
        </div>

        <div class="mt-12 max-w-6xl min-w-0" id="download">
          <h2
            class="font-bold text-2xl text-slate-950 md:text-3xl dark:text-white"
          >
            {t("download.sectionTitle")}
          </h2>

          <div
            class="mt-6 rounded-lg border border-slate-200 bg-slate-50/80 p-5 dark:border-slate-700 dark:bg-slate-900/30"
          >
            <div class="flex items-start gap-3">
              <ShieldCheck
                className="mt-0.5 h-5 w-5 shrink-0 text-slate-500 dark:text-slate-300"
                aria-hidden="true"
              />
              <div class:list={["min-w-0", lang === "ja" && "budoux-ja"]}>
                <h3
                  class="font-semibold text-slate-950 text-sm sm:text-base dark:text-white"
                >
                  {formatText(sourceCheckEntry.data.title)}
                </h3>
                <div
                  class="mt-2 text-slate-700 text-sm leading-6 sm:text-base sm:leading-7 dark:text-slate-200 [&_a]:font-medium [&_a]:text-slate-900 [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-slate-950 [&_code]:break-words [&_code]:rounded [&_code]:bg-slate-100 [&_code]:px-1 [&_code]:py-0.5 [&_code]:text-slate-900 [&_p]:m-0 [&_p+p]:mt-3 dark:[&_a]:text-white dark:[&_code]:bg-slate-800 dark:[&_code]:text-slate-100"
                >
                  <SourceCheckContent />
                </div>
              </div>
            </div>
          </div>

          <div class="mt-8">
            <Download
              client:visible
              embedded
              showHeader={false}
              showLatestChanges={false}
              showFooterLinks={false}
              downloads={downloads}
              latestVersion={latestVersion}
              latestReleaseDetails={latestReleaseDetails}
              translations={downloadTranslations}
            />
          </div>
        </div>

        <div
          id="installation"
          class="mt-16 min-w-0 border-slate-200 border-t pt-12 md:mt-20 md:pt-16 dark:border-slate-700"
        >
          <article
            class:list={[guideArticleClass, lang === "ja" && "budoux-ja"]}
          >
            <h2>{installationEntry.data.title}</h2>
            <InstallationContent />
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
